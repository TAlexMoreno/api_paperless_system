COMPOSE_PROJECT_NAME=paperless

# Port forwarding for different services
REDIS_PORT=6379
POSTGRES_PORT=5432
GOTENBERG_PORT=3000
TIKA_PORT=9998
PAPERLESS_PORT=8088

# n8n credentials
N8N_INSTANCE_OWNER_EMAIL=owner@example.com
N8N_INSTANCE_OWNER_NAME=Your Name
# Generate with: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourStrongPassword', bcrypt.gensalt()).decode())"
N8N_INSTANCE_OWNER_PASSWORD_HASH=$2b$12$replace_with_generated_bcrypt_hash
